# Database
MONGO_URI=mongodb://localhost:27017/seva-setu

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Frontend URL
FRONTEND_URL=https://seva-setu-six.vercel.app

# Backend URL (Absolute URL, e.g., https://your-app.herokuapp.com)
BACKEND_URL=

# Server
PORT=5000

# ─── Twilio WhatsApp Sandbox ───────────────────────────────────────────────────
# Get these from https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
# Sandbox number is always this (do NOT change for test environment):
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Optional: Content Template SID for provider welcome message (from Twilio Console)
# If set, uses template-based messages; otherwise falls back to plain text
TWILIO_PROVIDER_WELCOME_TEMPLATE_SID=your_template_sid_here
# ──────────────────────────────────────────────────────────────────────────────