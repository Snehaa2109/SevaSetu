# --- Dependencies ---
# Ignores node_modules in root and all subfolders
node_modules/
**/node_modules/

# --- Environment Variables ---
# Crucial: Keep your MONGODB_URI and PORT private
.env
backend/.env
frontend/.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- Build & Production ---
# React build folder
frontend/build/
frontend/dist/

# --- Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
backend/*.log
frontend/*.log

# --- Testing ---
# Coverage reports if you add Vitest/Jest later
coverage/
frontend/coverage/
backend/coverage/

# --- OS & IDE Files ---
.DS_Store
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
